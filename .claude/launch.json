{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "design-preview",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "7799", "--directory", "/tmp/design-preview"],
      "port": 7799
    },
    {
      "name": "nextjs-dev",
      "runtimeExecutable": "pnpm",
